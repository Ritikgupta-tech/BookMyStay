<% layout("/layouts/boilerplate") %>

<!-- Hero Section -->

<div class="hero-section text-center">

    <h1>Find Your Perfect Stay</h1>

    <p>Discover amazing hotels, villas and apartments around the world.</p>

    <a href="/listings/new" class="btn btn-danger btn-lg hero-btn">
        Become a Host
    </a>

</div>

<!-- Categories -->

<div id="filters">

    <div class="filter">
        <i class="fa-solid fa-fire fa-xl"></i>
        <p>Trending</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-bed fa-xl"></i>
        <p>Rooms</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-mountain fa-xl"></i>
        <p>Mountains</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-person-swimming fa-xl"></i>
        <p>Pools</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-campground fa-xl"></i>
        <p>Camping</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-tree fa-xl"></i>
        <p>Nature</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-hotel fa-xl"></i>
        <p>Hotels</p>
    </div>

    <div class="filter">
        <i class="fa-solid fa-house fa-xl"></i>
        <p>Homes</p>
    </div>

</div>

<hr>

<!-- Listings -->

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">

<% for(let listing of allListings){ %>

<a href="/listings/<%= listing._id %>" class="listing-link">

<div class="card listing-card h-100">

<img
src="<%= listing.image.url %>"
class="card-img-top listing-img"
alt="<%= listing.title %>">

<div class="card-img-overlay overlay">

</div>

<div class="card-body">

<div class="d-flex justify-content-between align-items-center">

<h5 class="mb-0">

<%= listing.title %>

</h5>

<span class="text-warning">

<i class="fa-solid fa-star"></i>

4.8

</span>

</div>

<p class="text-muted mb-2">

📍 <%= listing.location %>

</p>

<h6 class="text-danger">

₹ <%= listing.price.toLocaleString("en-IN") %>

<span class="text-dark fw-normal">

/ night

</span>

</h6>

</div>

</div>

</a>

<% } %>

</div>